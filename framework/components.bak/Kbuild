#
# Kbuild for framework components
#

ifeq (${CONFIG_COMPONENTS_DEMUXER}, y)
    KBUILD_DEFINES += -DCOMPONENTS_DEMUXER_ON
endif

ifeq (${CONFIG_FLUSH_MOOV_STREAM}, y)
    KBUILD_DEFINES += -DFLUSH_MOOV_STREAM_ON
endif

ifeq (${CONFIG_COMPONENTS_PLAYER}, y)
    KBUILD_DEFINES += -DCOMPONENTS_PLAYER_ON
endif

ifeq (${CONFIG_COMPONENTS_EVENT_REC_FILE_COPY_FROM_NORM}, y)
    KBUILD_DEFINES += -DEVENT_REC_FILE_COPY_FROM_NORM_ON
endif

ifeq (${CONFIG_COMPONENTS_THUMBNAIL_EXTRACTOR}, y)
    KBUILD_DEFINES += -DCOMPONENTS_THUMBNAIL_EXTRACTOR_ON
endif

ifeq (${CONFIG_COMPONENTS_FILE_RECOVER}, y)
    KBUILD_DEFINES += -DCOMPONENTS_FILE_RECOVER_ON
endif