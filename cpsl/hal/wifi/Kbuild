#
# Kbuild for wifi
#

ifeq (${CONFIG_WIFI}, y)
    KBUILD_DEFINES += -DCONFIG_WIFI_ON
endif

ifeq (${CONFIG_WIFI_RTL8189}, y)
    KBUILD_DEFINES += -DCONFIG_WIFI_RTL8189
else ifeq (${CONFIG_WIFI_AP6201BM}, y)
    KBUILD_DEFINES += -DCONFIG_WIFI_AP6201BM
else ifeq (${CONFIG_WIFI_HI3881}, y)
    KBUILD_DEFINES += -DCONFIG_WIFI_HI3881
else ifeq (${CONFIG_WIFI_RTL8188}, y)
    KBUILD_DEFINES += -DCONFIG_WIFI_RTL8188
else ifeq (${CONFIG_WIFI_AIC8800}, y)
    KBUILD_DEFINES += -DCONFIG_WIFI_AIC8800
endif