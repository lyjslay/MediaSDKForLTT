diff --git a/driver/hcc/hcc_host.c b/driver/hcc/hcc_host.c
index 99e0c86..18ab252 100644
--- a/driver/hcc/hcc_host.c
+++ b/driver/hcc/hcc_host.c
@@ -876,7 +876,17 @@
     }
 
     if (hcc_handler->hi_channel && hcc_handler->hi_channel->func) {
-        ret = oal_sdio_get_credit(hcc_handler->hi_channel, &priority_cnt);
+        hi_u32 *p = (hi_u32 *)hi_malloc(HI_MOD_ID_WIFI_DRV, sizeof(hi_u32));
+        if (p == HI_NULL) {
+            hcc_tx_transfer_unlock(hcc_handler);
+            hcc_clear_tx_queues(hcc_handler);
+            hcc_delay_time();
+            return 0;
+        }
+        *p = 0;
+        ret = oal_sdio_get_credit(hcc_handler->hi_channel, p);
+        priority_cnt = *p;
+        hi_free(HI_MOD_ID_WIFI_DRV, p);
         if (ret < 0) {
             hcc_tx_transfer_unlock(hcc_handler);
             hcc_clear_tx_queues(hcc_handler);
