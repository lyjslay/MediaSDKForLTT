diff --git a/driver/mac/hmac/dmac_ext_if.h b/driver/mac/hmac/dmac_ext_if.h
index 19735fe..17cd475 100755
--- a/driver/mac/hmac/dmac_ext_if.h
+++ b/driver/mac/hmac/dmac_ext_if.h
@@ -649,6 +649,11 @@
 
 typedef dmac_config_syn_stru hmac_config_syn_stru;
 
+typedef struct {
+    hi_u32 tv_sec;
+    hi_u32 tv_usec;
+} dmac_timestamp_stru;
+
 /* tx cb字段 当前已用19字节，只有20字节可用 不允许再增加字节! */
 struct dmac_tx_ctl {
     /* ampdu中包含的MPDU个数,实际描述符填写的值为此值-1 */
@@ -688,7 +693,7 @@
 
     hi_u8                               alg_pktno;                     /* 算法用到的字段，唯一标示该报文 */
 
-    struct timeval                      timestamp_us;                  /* 维测使用入TID队列时的时间戳 */
+    dmac_timestamp_stru                 timestamp_us;                  /* 维测使用入TID队列时的时间戳 */
 
     hi_u8                               tid                     : 4;
     hi_u8                               tx_user_idx_bak         : 4;
@@ -1023,7 +1028,6 @@
     hi_u8                               rsv[4];          /* 替换hal_tx_dscr_stru resv 4 byte */
     hi_u16                              us_eapol_ts;     /* eapol帧时间戳 */
     hi_u16                              us_mpdu_bytes;   /* mpdu字节数，维测用，不包括头尾，不包括snap，不包括padding */
-    struct timeval                      timestamp_us;    /* 维测使用入TID队列时的时间戳 */
 
     hi_u32                              alg_pktno;       /* 算法用到的字段，唯一标示该报文 */
     hi_u16                              us_seqnum;       /* 记录软件分配的seqnum */
