CHIP_ARCH := $(shell echo $(CHIP_TYPE) | tr '[:lower:]' '[:upper:]')

KBUILD_DEFINES += -DCHIP_TYPE=\"$(CHIP_TYPE)\" -DCHIP_ARCH=\"$(CHIP_TYPE)\"

export CHIP_ARCH

ifeq ($(CONFIG_WEVB_0007A), y)
	BOARD_TYPE := wevb_0007a
else ifeq ($(CONFIG_WEVB_0006A), y)
	BOARD_TYPE := wevb_0006a
else ifeq ($(CONFIG_WDMB_0006A), y)
	BOARD_TYPE := wdmb_0006a
else ifeq ($(CONFIG_WEVB_0008A), y)
    BOARD_TYPE := wevb_0008a
else ifeq ($(CONFIG_WEVB_0009A), y)
    BOARD_TYPE := wevb_0009a
endif

ifeq ($(CONFIG_64BIT), y)
	KBUILD_DEFINES += -DARCH_64BIT
else ifeq ($(CONFIG_32BIT), y)
	KBUILD_DEFINES += -DARCH_32BIT
endif

ifeq ($(CONFIG_DDR_64M), y)
	BOARD_DDR := 64M
	KBUILD_DEFINES += -DDDR_64M
else ifeq ($(CONFIG_DDR_128M), y)
	BOARD_DDR := 128M
	KBUILD_DEFINES += -DDDR_128M
else ifeq ($(CONFIG_DDR_256M), y)
	BOARD_DDR := 256M
	KBUILD_DEFINES += -DDDR_256M
else ifeq ($(CONFIG_DDR_512M), y)
	BOARD_DDR := 512M
	KBUILD_DEFINES += -DDDR_512M
endif

