# 12 "/media/cvitek/yijun.liu01/car/mars/litiantai/pnd-ltt/MediaSDK/platform/u-boot-2021.10/arch/arm/dts/cv181x_base_arm.dtsi" 2

/ {
 model = "Cvitek. Mars ASIC. ARM.";
 interrupt-parent = <&gic>;

 #size-cells = <0x2>;
 #address-cells = <0x2>;

 gic: interrupt-controller {
  compatible = "arm,cortex-a15-gic";
  ranges;
  #size-cells = <0x2>;
  #address-cells = <0x2>;
  interrupt-controller;
  #interrupt-cells = <0x3>;
  reg = <0x0 0x01F01000 0x0 0x1000>,
        <0x0 0x01F02000 0x0 0x2000>;
 };

 pmu_a53 {
  compatible = "arm,cortex-a53-pmu";
  interrupts = <0 119 4>,
        <0 120 4>;
  interrupt-affinity = <&A53_0>;
 };

 psci {
  migrate = <0xc4000005>;
  cpu_on = <0xc4000003>;
  cpu_off = <0x84000002>;
  cpu_suspend = <0xc4000001>;
  sys_poweroff = <0x84000008>;
  sys_reset = <0x84000009>;
  method = "smc";
  compatible = "arm,psci-0.2", "arm,psci";
 };

 cpus {
  #size-cells = <0x0>;
  #address-cells = <0x1>;

  A53_0: cpu@0 {
   reg = <0x0>;
   enable-method = "psci";
   compatible = "arm,cortex-a53";
   device_type = "cpu";
   next-level-cache = <&CA53_L2>;
  };

  CA53_L2: l2-cache0 {
   compatible = "cache";
  };
 };

 timer {
  interrupts = <1 13 ((((1 << (2)) - 1) << 8) | 8)>,
   <1 14 ((((1 << (2)) - 1) << 8) | 8)>,
   <1 11 ((((1 << (2)) - 1) << 8) | 8)>,
   <1 10 ((((1 << (2)) - 1) << 8) | 8)>;
  always-on;
  clock-frequency = <25000000>;
  compatible = "arm,armv8-timer";
 };

 firmware {
  optee {
   compatible = "linaro,optee-tz";
   method = "smc";
  };
 };

 cv181x_cooling:cv181x_cooling {
  clocks = <&clk 8>, <&clk 12>;
  clock-names = "clk_cpu", "clk_tpu_axi";
  dev-freqs = <800000000 500000000>,
   <400000000 375000000>,
   <400000000 300000000>;
  compatible = "cvitek,cv181x-cooling";
  #cooling-cells = <2>;
 };

 tpu {
  interrupts = <0 59 1>,
        <0 60 1>;
 };

 mon {
  interrupts = <0 77 1>;
 };

 wiegand0 {
  interrupts = <0 48 4>;
 };

 wiegand1 {
  interrupts = <0 49 4>;
 };

 wiegand2 {
  interrupts = <0 50 4>;
 };

 saradc {
  interrupts = <0 84 1>;
 };

 rtc {
  interrupts = <0 1 4>;
 };

 sysdma_remap {
  int_mux = <0x1FF>;
 };

 dmac: dma@0x4330000 {
  interrupts = <0 13 4>;
 };







 spinand:cv-spinf@4060000 {
  interrupts = <0 23 4>;
 };

 spif:cvi-spif@10000000 {
  interrupts = <0 79 4>;
 };

 spi0:spi0@04180000 {
  interrupts = <0 38 4>;
 };

 spi1:spi1@04190000 {
  interrupts = <0 39 4>;
 };

 spi2:spi2@041A0000 {
  interrupts = <0 40 4>;
 };

 spi3:spi3@041B0000 {
  interrupts = <0 41 4>;
 };

 uart0: serial@04140000 {
  interrupts = <0 28 4>;
 };

 uart1: serial@04150000 {
  interrupts = <0 29 4>;
 };

 uart2: serial@04160000 {
  interrupts = <0 30 4>;
 };

 uart3: serial@04170000 {
  interrupts = <0 31 4>;
 };

 uart4: serial@041C0000 {
  interrupts = <0 32 4>;
 };

 gpio0: gpio@03020000 {
  porta: gpio-controller@0 {
   interrupt-controller;
   interrupts = <0 44 4>;
  };
 };

 gpio1: gpio@03021000 {
  portb: gpio-controller@1 {
   interrupt-controller;
   interrupts = <0 45 4>;
  };
 };

 gpio2: gpio@03022000 {
  portc: gpio-controller@2 {
   interrupt-controller;
   interrupts = <0 46 4>;
  };
 };

 gpio3: gpio@03023000 {
  portd: gpio-controller@3 {
   interrupt-controller;
   interrupts = <0 47 4>;
  };
 };

 gpio4: gpio@05021000 {
  porte: gpio-controller@4 {
   interrupt-controller;
   interrupts = <0 54 4>;
  };
 };

 i2c0: i2c@04000000 {
  interrupts = <0 33 4>;
 };

 i2c1: i2c@04010000 {
  interrupts = <0 34 4>;
 };

 i2c2: i2c@04020000 {
  interrupts = <0 35 4>;
 };

 i2c3: i2c@04030000 {
  interrupts = <0 36 4>;
 };

 i2c4: i2c@04040000 {
  interrupts = <0 37 4>;
 };

 ethernet0: ethernet@4070000 {
  interrupt-names = "macirq";
  interrupts = <0 15 4>;
 };

 emmc:cv-emmc@4300000 {
  interrupts = <0 18 4>;
 };

 sd:cv-sd@4310000 {
  interrupts = <0 20 4>;
 };

 i2s0: i2s@04100000 {
  interrupts = <0 24 4>;
 };

 i2s1: i2s@04110000 {
  interrupts = <0 25 4>;
 };

 i2s2: i2s@04120000 {
  interrupts = <0 26 4>;
 };

 i2s3: i2s@04130000 {
  interrupts = <0 27 4>;
 };

 wifisd:wifi-sd@4320000 {
  interrupts = <0 22 4>;
 };

 mipi_rx: cif {
  interrupts = <0 10 4>,
        <0 11 4>;
  interrupt-names = "csi0", "csi1";
 };

 vi {
  interrupts = <0 8 4>;
  interrupt-names = "isp";
 };

 ive {
  interrupt-names = "ive_irq";
  interrupts = <0 81 1>;
 };

 vpss {
  interrupts = <0 9 4>;
  interrupt-names = "sc";
 };

 dwa {
  interrupts = <0 12 4>;
  interrupt-names = "dwa";
 };

 vcodec {
  interrupts = <0 6 4>,
        <0 5 4>,
        <0 7 4>;
  interrupt-names = "h265","h264","sbm";
 };

 jpu {
  interrupts = <0 4 4>;
  interrupt-names = "jpeg";
 };

 rtos_cmdqu {
  interrupts = <0 85 4>;
  interrupt-names = "mailbox";
 };

 usb: usb@04340000 {
  interrupts = <0 14 4>;
 };

 thermal:thermal@030E0000 {
  interrupts = <0 0 4>;
  interrupt-names = "tempsen";
 };

};
