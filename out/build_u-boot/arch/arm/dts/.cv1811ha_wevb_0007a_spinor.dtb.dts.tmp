/ {
 memory@80000000 {
  device_type = "memory";
  reg = <0x00 0x80000000 0x00 0x8000000>;
 };


 fast_image {
  compatible = "cvitek,rtos_image";
  reg-names = "rtos_region";
  reg = <0x0 0x84400000 0x0 0x3c00000>;
  ion-size = <0x390000>;
 };

 reserved-memory {
  #size-cells = <0x2>;
  #address-cells = <0x2>;
  ranges;

  ion_reserved: ion {
   compatible = "ion-region";
   alloc-ranges = <0x0 0x83980000 0 0xa80000>;
   size = <0x0 0xa80000>;
  };

  rtos_reserved: rtos {
   compatible = "rtos-region";
   alloc-ranges = <0x0 0x84400000 0 0x3c00000>;
   size = <0x0 0x3c00000>;
  };
 };

    alios_log {
  reg = <0x00 0x87f90000 0x00 0x20000>;
  reg-names = "alios_log_base";
  compatible = "cvitek,alios_log";
 };
};
