/ {
 i2c1gpio: i2c1-gpio {
  compatible = "i2c-gpio";
  sda-gpios = <&porta 17 (0 | (2 | 4))>;
  scl-gpios = <&porta 16 (0 | (2 | 4))>;
  #size-cells = <0x0>;
  #address-cells = <0x1>;
  i2c-gpio,delay-us = <5>;
  status = "okay";
  gt9xx: gt9xx@5d {
     compatible = "goodix,gt9xx";
     reg = <0x5d>;
     status = "okay";
    };
 };
};
